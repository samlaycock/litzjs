{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "paths": {
      "litz": ["./src/index.ts"],
      "litz/client": ["./src/client/index.ts"],
      "litz/server": ["./src/server/index.ts"],
      "litz/vite": ["./src/vite.ts"]
    },
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "types": ["bun-types"],

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    /* If NOT transpiling with TypeScript: */
    "module": "preserve",
    "noEmit": true,

    /* If your code doesn't run in the DOM: */
    "lib": ["es2022", "dom", "dom.iterable"]
  },
  "exclude": ["dist", "fixtures/**/dist", "node_modules", "www", "fixtures"]
}
