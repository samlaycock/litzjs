{
  "name": "litzjs",
  "version": "0.4.0",
  "description": "Client-first React framework with RSC support built on Vite",
  "keywords": [
    "framework",
    "react",
    "react-server-components",
    "rsc",
    "vite"
  ],
  "license": "MIT",
  "repository": {
    "url": "https://github.com/samlaycock/litzjs"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/client.js",
    "./dist/client.mjs"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./server/nitro": {
      "types": "./dist/server/nitro.d.ts",
      "import": "./dist/server/nitro.mjs",
      "require": "./dist/server/nitro.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.js"
    },
    "./vite/nitro": {
      "types": "./dist/vite-nitro.d.ts",
      "import": "./dist/vite-nitro.mjs",
      "require": "./dist/vite-nitro.js"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --type-aware --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check",
    "test": "bun test",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun test && bun run build && bun run fixture:build",
    "prepublishOnly": "bun run check",
    "ci:publish": "bun run check && changeset publish",
    "fixture:dev": "vite --config fixtures/rsc-smoke/vite.config.ts",
    "fixture:build": "vite build --config fixtures/rsc-smoke/vite.config.ts"
  },
  "dependencies": {
    "@vitejs/plugin-rsc": "0.5.26",
    "nitro": "3.0.260429-beta",
    "picomatch": "4.0.4",
    "tinyglobby": "0.2.16",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@cloudflare/vite-plugin": "1.36.3",
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.2",
    "@types/picomatch": "4.0.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bun-types": "1.3.13",
    "happy-dom": "20.9.0",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsdown": "0.22.0",
    "unrun": "0.2.37",
    "vite": "8.0.11",
    "vite-plugin-pwa": "1.3.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.0"
  }
}
