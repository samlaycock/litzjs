{
  "name": "litzjs",
  "version": "1.0.0",
  "description": "Client-first React framework with RSC support built on Vite",
  "keywords": [
    "framework",
    "react",
    "react-server-components",
    "rsc",
    "vite"
  ],
  "license": "MIT",
  "repository": {
    "url": "https://github.com/samlaycock/litzjs"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/client.js",
    "./dist/client.mjs"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./server/nitro": {
      "types": "./dist/server/nitro.d.ts",
      "import": "./dist/server/nitro.mjs",
      "require": "./dist/server/nitro.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.js"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --type-aware --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun test && bun run build && bun run fixture:build",
    "prepublishOnly": "bun run check",
    "ci:publish": "bun run check && changeset publish",
    "fixture:dev": "vite --config fixtures/rsc-smoke/vite.config.ts",
    "fixture:build": "vite build --config fixtures/rsc-smoke/vite.config.ts"
  },
  "dependencies": {
    "picomatch": "4.0.4",
    "tinyglobby": "0.2.15"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@cloudflare/vite-plugin": "^1.30.2",
    "@types/node": "25.5.0",
    "@types/picomatch": "4.0.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-rsc": "0.5.21",
    "bun-types": "1.3.11",
    "happy-dom": "20.8.9",
    "nitro": "3.0.260311-beta",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsdown": "0.21.7",
    "vite": "8.0.3",
    "vite-plugin-pwa": "1.2.0"
  },
  "peerDependencies": {
    "@vitejs/plugin-rsc": "^0.5.21",
    "nitro": "^3",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^6.0.2",
    "vite": "^8"
  }
}
